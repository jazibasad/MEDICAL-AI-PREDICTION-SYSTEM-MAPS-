@{
    ViewData["Title"] = "Patient Dashboard";
    Layout = "_PatientLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-house-heart text-primary"></i> My Health Dashboard</h1>
    <small class="text-muted" id="last-updated"></small>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card bg-white shadow-sm border-start border-primary border-4">
            <div class="stat-value text-primary" id="stat-score">—</div>
            <div class="stat-label">Risk Score</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card bg-white shadow-sm border-start border-success border-4">
            <div class="stat-value text-success" id="stat-preds">—</div>
            <div class="stat-label">AI Insights Shared</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card bg-white shadow-sm border-start border-info border-4">
            <div class="stat-value text-info" id="stat-rx">—</div>
            <div class="stat-label">Active Prescriptions</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card bg-white shadow-sm border-start border-warning border-4">
            <div class="stat-value text-warning" id="stat-msgs">—</div>
            <div class="stat-label">New Messages</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Assigned Doctor Card -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-person-badge-fill text-primary me-2"></i>My Doctor
            </div>
            <div class="card-body text-center">
                <div class="doctor-avatar mb-3" id="doctor-avatar">?</div>
                <h6 class="fw-bold" id="doctor-name">Loading...</h6>
                <p class="text-muted small" id="doctor-spec"></p>
                <a href="/patient/chat" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-chat-dots me-1"></i> Message Doctor
                </a>
            </div>
        </div>

        <!-- Risk Card -->
        <div class="card mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-activity me-2"></i>Risk Level
            </div>
            <div class="card-body text-center">
                <div id="tier-display" class="fs-4 fw-bold mb-1">—</div>
                <p class="text-muted small">Your assigned risk category based on health data.</p>
                <small class="text-muted">Managed by your doctor.</small>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header fw-semibold">Quick Actions</div>
            <div class="card-body d-grid gap-2">
                <a href="/patient/appointments/book" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-calendar-plus me-1"></i> Book Appointment
                </a>
                <a href="/patient/health" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-file-medical me-1"></i> My Health Records
                </a>
                <a href="/patient/feedback" class="btn btn-outline-warning btn-sm">
                    <i class="bi bi-star me-1"></i> Submit Feedback
                </a>
            </div>
        </div>
    </div>

    <!-- Upcoming Appointments -->
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">
                    <i class="bi bi-calendar-check text-success me-2"></i>Upcoming Appointments
                </span>
                <a href="/patient/appointments" class="btn btn-sm btn-outline-success">View All</a>
            </div>
            <div class="list-group list-group-flush" id="upcoming-list">
                <div class="list-group-item text-center text-muted py-3">
                    <div class="spinner-border spinner-border-sm"></div>
                </div>
            </div>
        </div>

        <!-- Disclaimer Box -->
        <div class="alert alert-info d-flex gap-2">
            <i class="bi bi-info-circle-fill fs-5 flex-shrink-0 mt-1"></i>
            <div>
                <strong>About AI Insights:</strong> All AI predictions and health insights shown
                here have been reviewed and shared by your assigned doctor. Do not make medical
                decisions based solely on these results — always consult your doctor.
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const token = localStorage.getItem('maps_token');
const tierColors = {
    Emergency: 'text-danger', Urgent: 'text-warning',
    Normal: 'text-primary',   Followup: 'text-success', Unknown: 'text-muted'
};

async function loadDashboard() {
    const res  = await fetch('/api/patient/dashboard', {
        headers: { Authorization: 'Bearer ' + token }
    });
    const json = await res.json();
    const d    = json.data;

    document.getElementById('stat-score').textContent = d.currentRiskScore.toFixed(1);
    document.getElementById('stat-preds').textContent = d.sharedPredictions;
    document.getElementById('stat-rx').textContent    = d.activePrescriptions;
    document.getElementById('stat-msgs').textContent  = d.unreadMessages;
    document.getElementById('last-updated').textContent = 'Updated ' + new Date().toLocaleTimeString();

    // Doctor
    const initials = d.assignedDoctorName.split(' ').map(n => n[0]).join('').substring(0, 2);
    document.getElementById('doctor-avatar').textContent = initials;
    document.getElementById('doctor-name').textContent   = d.assignedDoctorName;
    document.getElementById('doctor-spec').textContent   = d.assignedDoctorSpec;

    // Risk tier
    const tierEl = document.getElementById('tier-display');
    tierEl.textContent  = d.urgencyTier;
    tierEl.className    = `fs-4 fw-bold mb-1 ${tierColors[d.urgencyTier] || 'text-muted'}`;

    // Upcoming appointments
    document.getElementById('upcoming-list').innerHTML =
        d.upcomingAppointments.length === 0
        ? '<div class="list-group-item text-muted text-center py-3">No upcoming appointments</div>'
        : d.upcomingAppointments.map(a => `
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>${a.doctorName}</strong>
                        <span class="text-muted small ms-2">${a.doctorSpec}</span>
                    </div>
                    <span class="badge bg-primary">${a.priorityTier}</span>
                </div>
                <small class="text-muted">
                    <i class="bi bi-clock me-1"></i>
                    ${new Date(a.dateTime).toLocaleString()}
                    · ${a.durationMinutes} min · ${a.status}
                </small>
            </div>`).join('');
}

loadDashboard();
setInterval(loadDashboard, 60000);
</script>
}
