@{
    ViewData["Title"] = "Messages";
    Layout = "_DoctorLayout";
}

<div class="chat-container">
    <!-- Contacts Sidebar -->
    <div class="contacts-panel" id="contacts-panel">
        <div class="contacts-header">
            <h6 class="fw-bold mb-0"><i class="bi bi-chat-dots me-2"></i>Messages</h6>
            <span class="badge bg-danger" id="total-unread" style="display:none">0</span>
        </div>
        <div class="contact-search p-2">
            <input type="text" class="form-control form-control-sm"
                   placeholder="Search contacts..." id="contact-search"
                   oninput="filterContacts(this.value)">
        </div>
        <div class="contacts-list" id="contacts-list">
            <div class="text-center text-muted p-3 small">
                <div class="spinner-border spinner-border-sm"></div> Loading...
            </div>
        </div>
    </div>

    <!-- Chat Window -->
    <div class="chat-window" id="chat-window">
        <!-- Chat Header -->
        <div class="chat-header" id="chat-header" style="display:none">
            <div class="d-flex align-items-center gap-3">
                <div class="contact-avatar" id="chat-avatar">?</div>
                <div>
                    <div class="fw-bold" id="chat-name">—</div>
                    <small class="text-muted" id="chat-role">—</small>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" onclick="generateReport()">
                    <i class="bi bi-file-pdf me-1"></i> Report
                </button>
            </div>
        </div>

        <!-- Messages Area -->
        <div class="messages-area" id="messages-area">
            <div class="text-center text-muted py-5" id="select-prompt">
                <i class="bi bi-chat-dots fs-1 d-block mb-3 opacity-25"></i>
                Select a contact to start messaging
            </div>
        </div>

        <!-- Typing Indicator -->
        <div class="typing-indicator d-none" id="typing-indicator">
            <span id="typing-name"></span> is typing...
        </div>

        <!-- Input Bar -->
        <div class="chat-input-bar" id="chat-input-bar" style="display:none">
            <label class="btn btn-outline-secondary btn-sm" for="file-input">
                <i class="bi bi-paperclip"></i>
                <input type="file" id="file-input" class="d-none"
                       accept=".jpg,.jpeg,.png,.pdf,.docx"
                       onchange="uploadAttachment(this)">
            </label>
            <input type="text" class="form-control" id="message-input"
                   placeholder="Type a message..."
                   onkeydown="handleKeyDown(event)"
                   oninput="sendTyping(true)">
            <button class="btn btn-primary" onclick="sendMessage()">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
const token = localStorage.getItem('maps_token');
let connection, currentContactId, currentContactName;
let typingTimeout;
let allContacts = [];

// ── SignalR Connection ─────────────────────────────────────────────────────────
async function startSignalR() {
    connection = new signalR.HubConnectionBuilder()
        .withUrl('/api/chat', { accessTokenFactory: () => token })
        .withAutomaticReconnect()
        .build();

    connection.on('ReceiveMessage',  appendMessage);
    connection.on('MessageSent',     appendMessage);
    connection.on('TypingIndicator', handleTyping);
    connection.on('MessagesRead',    handleRead);
    connection.on('Notification',    handleNotification);

    await connection.start();
    console.log('SignalR connected');
}

// ── Load Contacts ──────────────────────────────────────────────────────────────
async function loadContacts() {
    const res  = await fetch('/api/chat/contacts', { headers: { Authorization: 'Bearer ' + token } });
    const json = await res.json();
    allContacts = json.data;
    renderContacts(allContacts);

    const totalUnread = allContacts.reduce((s, c) => s + c.unreadCount, 0);
    if (totalUnread > 0) {
        document.getElementById('total-unread').textContent = totalUnread;
        document.getElementById('total-unread').style.display = '';
    }
}

function renderContacts(contacts) {
    document.getElementById('contacts-list').innerHTML = contacts.map(c => `
        <div class="contact-item ${c.userId === currentContactId ? 'active' : ''}"
             onclick="openChat('${c.userId}', '${c.fullName}', '${c.role}')">
            <div class="contact-avatar-sm">${c.fullName.charAt(0)}</div>
            <div class="flex-grow-1 overflow-hidden">
                <div class="d-flex justify-content-between">
                    <strong class="small">${c.fullName}</strong>
                    ${c.unreadCount > 0
                        ? `<span class="badge bg-danger rounded-pill">${c.unreadCount}</span>`
                        : ''}
                </div>
                <div class="text-muted small text-truncate">
                    ${c.lastMessage?.content || 'No messages yet'}
                </div>
            </div>
        </div>`).join('');
}

function filterContacts(query) {
    const filtered = allContacts.filter(c =>
        c.fullName.toLowerCase().includes(query.toLowerCase()));
    renderContacts(filtered);
}

// ── Open Chat ─────────────────────────────────────────────────────────────────
async function openChat(contactId, name, role) {
    currentContactId   = contactId;
    currentContactName = name;

    document.getElementById('chat-avatar').textContent    = name.charAt(0);
    document.getElementById('chat-name').textContent      = name;
    document.getElementById('chat-role').textContent      = role;
    document.getElementById('chat-header').style.display  = '';
    document.getElementById('chat-input-bar').style.display = '';
    document.getElementById('select-prompt').style.display  = 'none';

    // Load message history
    const res  = await fetch(`/api/chat/history/${contactId}`, {
        headers: { Authorization: 'Bearer ' + token }
    });
    const json = await res.json();
    document.getElementById('messages-area').innerHTML = '';
    json.data.forEach(appendMessage);
    scrollToBottom();

    // Mark as read
    const unread = json.data.filter(m => !m.isRead && m.senderId === contactId)
                            .map(m => m.messageId);
    if (unread.length > 0 && connection)
        await connection.invoke('MarkRead', { messageIds: unread });

    loadContacts(); // Refresh unread counts
}

// ── Send Message ───────────────────────────────────────────────────────────────
async function sendMessage() {
    const input = document.getElementById('message-input');
    const text  = input.value.trim();
    if (!text || !currentContactId) return;

    input.value = '';
    sendTyping(false);

    await connection.invoke('SendMessage', {
        receiverId:  currentContactId,
        content:     text,
        messageType: 1 // Text
    });
}

function handleKeyDown(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
    }
}

// ── Typing ────────────────────────────────────────────────────────────────────
async function sendTyping(isTyping) {
    if (!currentContactId || !connection) return;
    clearTimeout(typingTimeout);
    await connection.invoke('SendTyping', currentContactId, isTyping);
    if (isTyping)
        typingTimeout = setTimeout(() => sendTyping(false), 2000);
}

function handleTyping(data) {
    if (data.senderId !== currentContactId) return;
    const el = document.getElementById('typing-indicator');
    document.getElementById('typing-name').textContent = data.senderName;
    el.classList.toggle('d-none', !data.isTyping);
}

// ── Append Message ─────────────────────────────────────────────────────────────
function appendMessage(msg) {
    if (msg.senderId !== currentContactId && msg.receiverId !== currentContactId) return;

    const myId  = JSON.parse(atob(token.split('.')[1])).uid;
    const isMine = msg.senderId === myId;
    const area   = document.getElementById('messages-area');

    const div = document.createElement('div');
    div.className = `message-bubble ${isMine ? 'mine' : 'theirs'}`;
    div.innerHTML = `
        <div class="bubble-content">${escapeHtml(msg.content)}</div>
        <div class="bubble-meta">
            ${new Date(msg.sentAt).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}
            ${isMine ? (msg.isRead ? ' ✓✓' : ' ✓') : ''}
        </div>`;
    area.appendChild(div);
    scrollToBottom();
}

function handleRead(messageIds) {
    // Update read receipts (double tick)
    document.querySelectorAll('.message-bubble.mine .bubble-meta').forEach(el => {
        if (el.textContent.includes('✓') && !el.textContent.includes('✓✓'))
            el.textContent = el.textContent.replace('✓', '✓✓');
    });
}

function handleNotification(data) {
    console.log('Notification:', data);
}

// ── File Upload ────────────────────────────────────────────────────────────────
async function uploadAttachment(input) {
    if (!input.files[0]) return;
    const form = new FormData();
    form.append('file', input.files[0]);
    const res  = await fetch('/api/chat/upload', {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token },
        body: form
    });
    const json = await res.json();
    if (json.success) {
        await connection.invoke('SendMessage', {
            receiverId:    currentContactId,
            content:       `📎 ${input.files[0].name}`,
            messageType:   2, // File
            attachmentKey: json.data.objectKey
        });
    }
}

async function generateReport() {
    if (!currentContactId) return;
    const res = await fetch(`/api/reports/patient-summary/${currentContactId}`, {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token }
    });
    const json = await res.json();
    if (json.success) window.open(json.data, '_blank');
}

const escapeHtml = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const scrollToBottom = () => {
    const area = document.getElementById('messages-area');
    area.scrollTop = area.scrollHeight;
};

// Init
startSignalR().then(loadContacts);
</script>

<style>
.chat-container { display: flex; height: calc(100vh - 80px); gap: 0; border-radius: 12px; overflow: hidden; background: white; box-shadow: 0 2px 16px rgba(0,0,0,0.08); }
.contacts-panel { width: 280px; border-right: 1px solid #e5e7eb; display: flex; flex-direction: column; flex-shrink: 0; }
.contacts-header { padding: 1rem; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
.contacts-list { flex: 1; overflow-y: auto; }
.contact-item { display: flex; align-items: center; gap: 10px; padding: 12px 16px; cursor: pointer; border-bottom: 1px solid #f3f4f6; }
.contact-item:hover { background: #f9fafb; }
.contact-item.active { background: #eff6ff; }
.contact-avatar { width: 36px; height: 36px; border-radius: 50%; background: #3b82f6; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0; }
.contact-avatar-sm { width: 36px; height: 36px; border-radius: 50%; background: #6b7280; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; flex-shrink: 0; }
.chat-window { flex: 1; display: flex; flex-direction: column; }
.chat-header { padding: 12px 16px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; background: white; }
.messages-area { flex: 1; overflow-y: auto; padding: 16px; background: #f9fafb; display: flex; flex-direction: column; gap: 8px; }
.typing-indicator { padding: 6px 16px; font-size: 12px; color: #6b7280; font-style: italic; }
.chat-input-bar { padding: 12px 16px; border-top: 1px solid #e5e7eb; display: flex; gap: 8px; align-items: center; background: white; }
.chat-input-bar .form-control { border-radius: 20px; }
.message-bubble { max-width: 70%; display: flex; flex-direction: column; }
.message-bubble.mine { align-self: flex-end; align-items: flex-end; }
.message-bubble.theirs { align-self: flex-start; align-items: flex-start; }
.bubble-content { padding: 10px 14px; border-radius: 16px; font-size: 14px; word-wrap: break-word; }
.mine .bubble-content { background: #3b82f6; color: white; border-bottom-right-radius: 4px; }
.theirs .bubble-content { background: white; border: 1px solid #e5e7eb; border-bottom-left-radius: 4px; }
.bubble-meta { font-size: 11px; color: #9ca3af; margin-top: 2px; }
</style>
}
