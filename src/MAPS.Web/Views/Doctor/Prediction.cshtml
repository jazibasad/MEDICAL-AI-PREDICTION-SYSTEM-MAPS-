@{
    ViewData["Title"] = "AI Disease Prediction";
    Layout = "_DoctorLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="bi bi-cpu-fill text-primary"></i> AI Disease Prediction
    </h1>
    <div class="alert alert-warning py-1 px-3 mb-0 small">
        <i class="bi bi-shield-exclamation me-1"></i>
        AI output is for clinical decision support only. Validate with clinical judgment.
    </div>
</div>

<div class="row g-3">
    <!-- Input Panel -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header fw-semibold">
                <i class="bi bi-input-cursor me-2 text-primary"></i>Prediction Input
            </div>
            <div class="card-body">
                <!-- Patient Select -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Patient</label>
                    <select class="form-select" id="patient-select">
                        <option value="">Select patient...</option>
                    </select>
                </div>

                <!-- Disease Type -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Disease Type</label>
                    <select class="form-select" id="disease-select" onchange="updateInputMode()">
                        <option value="1">Diabetes</option>
                        <option value="2">Heart Disease</option>
                        <option value="3">Pneumonia (Image)</option>
                        <option value="4">Brain Tumour (Image)</option>
                        <option value="5">Skin Cancer (Image)</option>
                    </select>
                </div>

                <!-- Input Modality Tabs -->
                <ul class="nav nav-tabs mb-3" id="modality-tabs">
                    <li class="nav-item">
                        <a class="nav-link active" href="#" onclick="setModality(1, this)">
                            <i class="bi bi-table me-1"></i>Structured
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" onclick="setModality(2, this)">
                            <i class="bi bi-image me-1"></i>Image
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" onclick="setModality(4, this)">
                            <i class="bi bi-chat-text me-1"></i>Text
                        </a>
                    </li>
                </ul>

                <!-- Structured Input (Diabetes / Heart) -->
                <div id="structured-panel">
                    <div id="diabetes-fields">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small">Glucose (mg/dL)</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="f-glucose" placeholder="e.g. 148">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">BMI</label>
                                <input type="number" step="0.1" class="form-control form-control-sm"
                                       id="f-bmi" placeholder="e.g. 33.6">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Age</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="f-age" placeholder="e.g. 50">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Blood Pressure</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="f-bp" placeholder="e.g. 72">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Insulin (μU/mL)</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="f-insulin" placeholder="e.g. 0">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Pregnancies</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="f-pregnancies" placeholder="e.g. 6">
                            </div>
                        </div>
                    </div>

                    <div id="heart-fields" style="display:none">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small">Age</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="h-age" placeholder="e.g. 54">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Cholesterol</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="h-cholesterol" placeholder="e.g. 240">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Resting BP</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="h-restingbp" placeholder="e.g. 130">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Max Heart Rate</label>
                                <input type="number" class="form-control form-control-sm"
                                       id="h-maxhr" placeholder="e.g. 150">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Chest Pain (0-3)</label>
                                <input type="number" min="0" max="3" class="form-control form-control-sm"
                                       id="h-chestpain" placeholder="0-3">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">ST Slope (0-2)</label>
                                <input type="number" min="0" max="2" class="form-control form-control-sm"
                                       id="h-stslope" placeholder="0-2">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Image Input -->
                <div id="image-panel" style="display:none">
                    <div class="border-2 border-dashed rounded p-4 text-center" id="drop-zone"
                         ondrop="handleDrop(event)" ondragover="event.preventDefault()">
                        <i class="bi bi-cloud-upload fs-1 text-muted d-block mb-2"></i>
                        <p class="text-muted mb-2">Drop medical image here or</p>
                        <label class="btn btn-outline-primary btn-sm">
                            Browse Files
                            <input type="file" id="image-input" class="d-none"
                                   accept=".jpg,.jpeg,.png,.dcm"
                                   onchange="previewImage(this)">
                        </label>
                        <div id="image-preview" class="mt-3" style="display:none">
                            <img id="preview-img" class="img-fluid rounded" style="max-height:200px">
                        </div>
                    </div>
                </div>

                <!-- Text Input -->
                <div id="text-panel" style="display:none">
                    <label class="form-label small fw-semibold">Clinical Description</label>
                    <textarea class="form-control" id="text-input" rows="5"
                              placeholder="Describe patient symptoms, history, and clinical findings...
e.g. 58-year-old male presenting with chest pain radiating to left arm, shortness of breath, diaphoresis for 2 hours. History of hypertension and smoking."></textarea>
                </div>

                <button class="btn btn-primary w-100 mt-3" id="predict-btn"
                        onclick="runPrediction()">
                    <i class="bi bi-cpu me-2"></i>Run AI Prediction
                </button>
            </div>
        </div>

        <!-- Differential Diagnosis Card -->
        <div class="card mt-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-list-ol text-purple me-2" style="color:#7c3aed"></i>
                Differential Diagnosis
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Symptoms (comma-separated)</label>
                    <input type="text" class="form-control form-control-sm" id="ddx-symptoms"
                           placeholder="fever, chest pain, shortness of breath">
                </div>
                <button class="btn btn-outline-purple btn-sm w-100"
                        style="border-color:#7c3aed;color:#7c3aed"
                        onclick="runDifferential()">
                    <i class="bi bi-diagram-3 me-1"></i>Generate Differentials
                </button>
            </div>
        </div>
    </div>

    <!-- Results Panel -->
    <div class="col-md-7">
        <!-- Loading State -->
        <div id="loading-state" class="card d-none">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary mb-3"></div>
                <p class="text-muted" id="loading-text">Running AI prediction...</p>
            </div>
        </div>

        <!-- Prediction Result -->
        <div id="result-card" class="card d-none">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">
                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                    Prediction Result
                </span>
                <button class="btn btn-sm btn-outline-success" onclick="shareWithPatient()">
                    <i class="bi bi-share me-1"></i>Share with Patient
                </button>
            </div>
            <div class="card-body">
                <!-- Primary Diagnosis -->
                <div class="p-3 rounded mb-3" style="background:#eff6ff;border-left:4px solid #3b82f6">
                    <div class="small text-muted mb-1">PRIMARY DIAGNOSIS</div>
                    <div class="fs-5 fw-bold" id="result-diagnosis">—</div>
                </div>

                <!-- Confidence Bar -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-semibold">Confidence Score</span>
                        <span class="small fw-bold" id="result-confidence-pct">—</span>
                    </div>
                    <div class="progress" style="height:10px">
                        <div class="progress-bar" id="result-confidence-bar"
                             role="progressbar" style="width:0%"></div>
                    </div>
                </div>

                <!-- Metadata -->
                <div class="row g-2 mb-3">
                    <div class="col-4">
                        <div class="stat-mini bg-light rounded p-2 text-center">
                            <div class="small text-muted">Disease</div>
                            <div class="fw-semibold small" id="result-disease">—</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini bg-light rounded p-2 text-center">
                            <div class="small text-muted">Modality</div>
                            <div class="fw-semibold small" id="result-modality">—</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini bg-light rounded p-2 text-center">
                            <div class="small text-muted">Status</div>
                            <div class="fw-semibold small text-success">Complete</div>
                        </div>
                    </div>
                </div>

                <!-- Doctor Interpretation -->
                <div class="mb-3">
                    <label class="form-label small fw-semibold">
                        Add Your Interpretation (required to share)
                    </label>
                    <textarea class="form-control form-control-sm" id="doctor-interpretation"
                              rows="3" placeholder="Add clinical context before sharing with patient..."></textarea>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary btn-sm" onclick="generateReport()">
                        <i class="bi bi-file-pdf me-1"></i>PDF Report
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="clearResult()">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </button>
                </div>
            </div>
        </div>

        <!-- Differential Results -->
        <div id="ddx-card" class="card mt-3 d-none">
            <div class="card-header fw-semibold" style="border-left:4px solid #7c3aed">
                <i class="bi bi-list-ol me-2" style="color:#7c3aed"></i>
                Differential Diagnoses
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0" id="ddx-table">
                    <thead class="table-light">
                        <tr>
                            <th>Rank</th>
                            <th>Condition</th>
                            <th>Probability</th>
                            <th>Confirmatory Tests</th>
                        </tr>
                    </thead>
                    <tbody id="ddx-tbody"></tbody>
                </table>
            </div>
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-cpu fs-1 text-muted d-block mb-3 opacity-25"></i>
                <p class="text-muted">Select a patient and input method, then run a prediction.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const token   = localStorage.getItem('maps_token');
let currentModality   = 1;
let currentPredId     = null;
let currentPatientId  = null;

// Load patient list on page load
async function loadPatients() {
    const res  = await fetch('/api/patients/queue', {
        headers: { Authorization: 'Bearer ' + token }
    });
    const json = await res.json();
    const sel  = document.getElementById('patient-select');
    json.data.forEach(p => {
        const opt    = document.createElement('option');
        opt.value    = p.patientId;
        opt.textContent = `${p.fullName} (Risk: ${p.riskScore.toFixed(0)} — ${p.urgencyTier})`;
        sel.appendChild(opt);
    });
}

function setModality(m, el) {
    currentModality = m;
    document.querySelectorAll('#modality-tabs .nav-link').forEach(l => l.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('structured-panel').style.display = m === 1 ? '' : 'none';
    document.getElementById('image-panel').style.display      = m === 2 ? '' : 'none';
    document.getElementById('text-panel').style.display       = m === 4 ? '' : 'none';
}

function updateInputMode() {
    const disease = parseInt(document.getElementById('disease-select').value);
    const diabetesFields = document.getElementById('diabetes-fields');
    const heartFields    = document.getElementById('heart-fields');

    if (disease === 1) {
        diabetesFields.style.display = '';
        heartFields.style.display    = 'none';
        setModality(1, document.querySelector('#modality-tabs .nav-link'));
    } else if (disease === 2) {
        diabetesFields.style.display = 'none';
        heartFields.style.display    = '';
        setModality(1, document.querySelector('#modality-tabs .nav-link'));
    } else {
        // Image diseases — auto-switch to image tab
        diabetesFields.style.display = 'none';
        heartFields.style.display    = 'none';
        setModality(2, document.querySelectorAll('#modality-tabs .nav-link')[1]);
    }
}

function previewImage(input) {
    if (!input.files[0]) return;
    const reader = new FileReader();
    reader.onload = e => {
        document.getElementById('preview-img').src = e.target.result;
        document.getElementById('image-preview').style.display = '';
    };
    reader.readAsDataURL(input.files[0]);
}

function handleDrop(e) {
    e.preventDefault();
    const file = e.dataTransfer.files[0];
    if (file) {
        document.getElementById('image-input').files = e.dataTransfer.files;
        previewImage(document.getElementById('image-input'));
    }
}

async function runPrediction() {
    const patientId = document.getElementById('patient-select').value;
    const disease   = parseInt(document.getElementById('disease-select').value);

    if (!patientId) { alert('Please select a patient.'); return; }

    currentPatientId = patientId;
    showLoading('Running AI prediction...');

    const body = {
        patientId,
        diseaseType:   disease,
        inputModality: currentModality,
        structuredFeatures: buildStructuredFeatures(disease),
        textPrompt: currentModality === 4
            ? document.getElementById('text-input').value
            : null
    };

    try {
        const res  = await fetch('/api/predictions', {
            method: 'POST',
            headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const json = await res.json();

        if (json.success) showResult(json.data);
        else { hideLoading(); alert('Prediction failed: ' + json.message); }
    } catch(e) {
        hideLoading();
        alert('Prediction error: ' + e.message);
    }
}

function buildStructuredFeatures(disease) {
    if (disease === 1) return {
        glucose: parseFloat(document.getElementById('f-glucose').value) || 0,
        bmi: parseFloat(document.getElementById('f-bmi').value) || 0,
        age: parseFloat(document.getElementById('f-age').value) || 0,
        bloodPressure: parseFloat(document.getElementById('f-bp').value) || 0,
        insulin: parseFloat(document.getElementById('f-insulin').value) || 0,
        pregnancies: parseFloat(document.getElementById('f-pregnancies').value) || 0
    };
    if (disease === 2) return {
        age: parseFloat(document.getElementById('h-age').value) || 0,
        cholesterol: parseFloat(document.getElementById('h-cholesterol').value) || 0,
        restingBP: parseFloat(document.getElementById('h-restingbp').value) || 0,
        maxHR: parseFloat(document.getElementById('h-maxhr').value) || 0,
        chestPain: parseFloat(document.getElementById('h-chestpain').value) || 0,
        stSlope: parseFloat(document.getElementById('h-stslope').value) || 0
    };
    return null;
}

async function runDifferential() {
    const patientId = document.getElementById('patient-select').value;
    const symptomsRaw = document.getElementById('ddx-symptoms').value;
    if (!patientId || !symptomsRaw) {
        alert('Select a patient and enter symptoms.');
        return;
    }

    const symptoms = symptomsRaw.split(',').map(s => s.trim()).filter(Boolean);
    showLoading('Generating differential diagnoses...');

    const res  = await fetch('/api/predictions/differential', {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ patientId, symptoms })
    });
    const json = await res.json();
    hideLoading();

    if (!json.success) { alert(json.message); return; }

    document.getElementById('empty-state').classList.add('d-none');
    document.getElementById('ddx-card').classList.remove('d-none');
    document.getElementById('ddx-tbody').innerHTML = json.data.map(d => `
        <tr>
            <td><span class="badge bg-secondary">#${d.rankPosition}</span></td>
            <td><strong>${d.condition}</strong>
                <div class="text-muted small">${d.reasoningChain.substring(0,80)}...</div>
            </td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height:6px">
                        <div class="progress-bar bg-purple" style="width:${d.probability*100}%;background:#7c3aed!important"></div>
                    </div>
                    <small class="fw-bold">${(d.probability*100).toFixed(0)}%</small>
                </div>
            </td>
            <td class="small text-muted">${(d.confirmatoryTests || []).slice(0,2).join(', ')}</td>
        </tr>`).join('');
}

function showResult(data) {
    hideLoading();
    currentPredId = data.predictionId;

    document.getElementById('empty-state').classList.add('d-none');
    document.getElementById('result-card').classList.remove('d-none');

    const pct = (data.confidence * 100).toFixed(1);
    document.getElementById('result-diagnosis').textContent     = data.primaryDiagnosis;
    document.getElementById('result-confidence-pct').textContent= pct + '%';
    document.getElementById('result-disease').textContent       = data.diseaseType;
    document.getElementById('result-modality').textContent      = ['','Structured','Image','','Text'][data.inputModality] || '—';

    const bar   = document.getElementById('result-confidence-bar');
    bar.style.width = pct + '%';
    bar.className   = 'progress-bar ' + (data.confidence > 0.7 ? 'bg-success' :
                                          data.confidence > 0.4 ? 'bg-warning' : 'bg-danger');
}

async function shareWithPatient() {
    if (!currentPredId) return;
    const interpretation = document.getElementById('doctor-interpretation').value;
    if (!interpretation) { alert('Please add your clinical interpretation first.'); return; }

    const res = await fetch('/api/predictions/share', {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ predictionId: currentPredId, doctorInterpretation: interpretation, recommendedNextSteps: [] })
    });
    const json = await res.json();
    alert(json.success ? '✅ Shared with patient successfully!' : '❌ ' + json.message);
}

async function generateReport() {
    if (!currentPredId) return;
    const res  = await fetch(`/api/reports/prediction/${currentPredId}`, {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token }
    });
    const json = await res.json();
    if (json.success) window.open(json.data, '_blank');
}

function showLoading(text) {
    document.getElementById('loading-text').textContent = text;
    document.getElementById('loading-state').classList.remove('d-none');
    document.getElementById('empty-state').classList.add('d-none');
    document.getElementById('result-card').classList.add('d-none');
    document.getElementById('predict-btn').disabled = true;
}

function hideLoading() {
    document.getElementById('loading-state').classList.add('d-none');
    document.getElementById('predict-btn').disabled = false;
}

function clearResult() {
    currentPredId = null;
    document.getElementById('result-card').classList.add('d-none');
    document.getElementById('empty-state').classList.remove('d-none');
    document.getElementById('doctor-interpretation').value = '';
}

loadPatients();
</script>
}
