@{
    ViewData["Title"] = "Patient Detail";
    Layout = "_DoctorLayout";
    var patientId = ViewBag.PatientId;
}

<div id="patient-header" class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/doctor/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/doctor/patients">Patients</a></li>
            <li class="breadcrumb-item active" id="breadcrumb-name">Loading...</li>
        </ol>
    </nav>
</div>

<div class="row g-3">
    <!-- Patient Info & Risk Card -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <div class="patient-avatar mb-3" id="patient-avatar">?</div>
                <h5 id="patient-name" class="fw-bold mb-1">Loading...</h5>
                <p id="patient-email" class="text-muted small mb-3"></p>
                <div class="d-flex justify-content-center gap-2 mb-3">
                    <span class="badge bg-secondary" id="patient-bloodgroup">—</span>
                    <span class="badge bg-info text-dark" id="patient-dob">—</span>
                </div>
            </div>
        </div>

        <!-- Risk Score Card -->
        <div class="card mb-3" id="risk-card">
            <div class="card-header fw-semibold">
                <i class="bi bi-activity me-2"></i>Risk Assessment
            </div>
            <div class="card-body text-center">
                <div class="risk-gauge mb-2">
                    <canvas id="riskGauge" width="150" height="80"></canvas>
                </div>
                <div class="risk-score h2 fw-bold" id="risk-score-val">—</div>
                <span class="badge fs-6" id="risk-tier-badge">Loading...</span>
                <div class="mt-2 small text-muted" id="risk-trend"></div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header fw-semibold">Quick Actions</div>
            <div class="card-body d-grid gap-2">
                <button class="btn btn-primary btn-sm"
                        onclick="window.location='/doctor/predictions/new?patient=@patientId'">
                    <i class="bi bi-cpu me-1"></i> AI Prediction
                </button>
                <button class="btn btn-success btn-sm"
                        onclick="window.location='/doctor/prescriptions/create/@patientId'">
                    <i class="bi bi-capsule me-1"></i> Prescribe
                </button>
                <button class="btn btn-info btn-sm text-white"
                        onclick="window.location='/doctor/notes/@patientId'">
                    <i class="bi bi-journal-text me-1"></i> Add Note
                </button>
                <button class="btn btn-warning btn-sm"
                        onclick="window.location='/doctor/chat?patient=@patientId'">
                    <i class="bi bi-chat-dots me-1"></i> Message Patient
                </button>
            </div>
        </div>
    </div>

    <!-- Timeline & Prescriptions -->
    <div class="col-md-8">
        <ul class="nav nav-tabs mb-3" id="patient-tabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#tab-timeline">
                    <i class="bi bi-clock-history me-1"></i>Timeline
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#tab-prescriptions">
                    <i class="bi bi-capsule me-1"></i>Prescriptions
                </a>
            </li>
        </ul>

        <div class="tab-content">
            <!-- Timeline Tab -->
            <div class="tab-pane fade show active" id="tab-timeline">
                <div class="timeline" id="timeline-container">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary"></div>
                    </div>
                </div>
            </div>

            <!-- Prescriptions Tab -->
            <div class="tab-pane fade" id="tab-prescriptions">
                <div id="prescriptions-container">Loading...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const token     = localStorage.getItem('maps_token');
const patientId = '@patientId';
const tierColors = {
    Emergency: '#ef4444', Urgent: '#f97316', Normal: '#3b82f6', Followup: '#10b981'
};

async function loadPatient() {
    const res  = await fetch(`/api/patients/${patientId}/timeline`, {
        headers: { Authorization: 'Bearer ' + token }
    });
    const json = await res.json();
    const d    = json.data;

    // Profile
    document.getElementById('patient-name').textContent   = d.profile.fullName;
    document.getElementById('patient-email').textContent  = d.profile.email;
    document.getElementById('breadcrumb-name').textContent = d.profile.fullName;
    document.getElementById('patient-avatar').textContent = d.profile.fullName.charAt(0).toUpperCase();
    document.getElementById('patient-bloodgroup').textContent = d.profile.bloodGroup || 'N/A';
    document.getElementById('patient-dob').textContent =
        d.profile.dateOfBirth ? new Date(d.profile.dateOfBirth).toLocaleDateString() : 'N/A';

    // Risk
    if (d.latestRisk) {
        const r     = d.latestRisk;
        const color = tierColors[r.urgencyTier] || '#6b7280';
        document.getElementById('risk-score-val').textContent    = r.riskScore.toFixed(1);
        document.getElementById('risk-score-val').style.color    = color;
        document.getElementById('risk-tier-badge').textContent   = r.urgencyTier;
        document.getElementById('risk-tier-badge').style.background = color;
        const trend = r.trendDirection === 'Worsening' ? '↑ Worsening' :
                      r.trendDirection === 'Improving' ? '↓ Improving' : '→ Stable';
        document.getElementById('risk-trend').textContent = trend;
    }

    // Timeline
    document.getElementById('timeline-container').innerHTML =
        d.events.length === 0
        ? '<p class="text-muted text-center py-4">No clinical events yet.</p>'
        : d.events.map(e => `
            <div class="timeline-item mb-3">
                <div class="d-flex gap-3">
                    <div class="timeline-icon" style="color:${e.color}">${e.icon}</div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <strong>${e.title}</strong>
                            <small class="text-muted">
                                ${new Date(e.timestamp).toLocaleDateString()}
                            </small>
                        </div>
                        <p class="text-muted small mb-0">${e.description}</p>
                    </div>
                </div>
            </div>`).join('');

    // Prescriptions
    document.getElementById('prescriptions-container').innerHTML =
        d.prescriptions.length === 0
        ? '<p class="text-muted text-center py-4">No prescriptions yet.</p>'
        : `<table class="table table-sm">
            <thead class="table-light">
              <tr><th>Medications</th><th>Status</th><th>Created</th><th>Expires</th></tr>
            </thead>
            <tbody>${d.prescriptions.map(p => `
              <tr>
                <td class="small">${p.medications}</td>
                <td><span class="badge bg-${p.status === 'Active' ? 'success':'secondary'}">${p.status}</span></td>
                <td class="small">${new Date(p.createdAt).toLocaleDateString()}</td>
                <td class="small">${p.expiresAt ? new Date(p.expiresAt).toLocaleDateString() : '—'}</td>
              </tr>`).join('')}
            </tbody>
           </table>`;
}

loadPatient();
</script>
}
