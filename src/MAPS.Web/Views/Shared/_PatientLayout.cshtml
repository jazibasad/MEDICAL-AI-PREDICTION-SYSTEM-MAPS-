<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MAPS Patient</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background: #f0fdf4; font-family: 'Segoe UI', system-ui, sans-serif; }
        .sidebar { width: 220px; min-height: 100vh; background: #1e3a2f; flex-shrink: 0; }
        .sidebar-brand { padding: 1.25rem 1rem; color: white; font-size: 1.1rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
        .sidebar .nav-link { color: rgba(255,255,255,0.8); border-radius: 6px; padding: 0.6rem 0.75rem; margin-bottom: 2px; font-size: 0.9rem; display: flex; align-items: center; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,0.15); color: white; }
        .main-content { flex-grow: 1; min-height: 100vh; }
        .stat-card { padding: 1rem; border-radius: 10px; }
        .stat-value { font-size: 1.8rem; font-weight: 700; }
        .stat-label { font-size: 0.75rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border-radius: 12px; }
        .card-header { border-radius: 12px 12px 0 0 !important; }
        .page-title { font-size: 1.5rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
        .doctor-avatar { width: 64px; height: 64px; border-radius: 50%; background: #059669; color: white; font-size: 1.5rem; font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto; }
    </style>
</head>
<body>
<div class="d-flex">
    <nav class="sidebar">
        <div class="sidebar-brand">💚 MAPS Patient</div>
        <hr class="border-secondary" />
        <ul class="nav flex-column px-2">
            <li class="nav-item"><a class="nav-link" href="/patient/dashboard"><i class="bi bi-house-heart me-2"></i>Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/patient/appointments"><i class="bi bi-calendar-check me-2"></i>Appointments</a></li>
            <li class="nav-item"><a class="nav-link" href="/patient/appointments/book"><i class="bi bi-calendar-plus me-2"></i>Book Appointment</a></li>
            <li class="nav-item"><a class="nav-link" href="/patient/health"><i class="bi bi-file-medical me-2"></i>Health Records</a></li>
            <li class="nav-item"><a class="nav-link" href="/patient/chat"><i class="bi bi-chat-dots me-2"></i>Messages <span class="badge bg-danger ms-auto" id="msg-badge" style="display:none">0</span></a></li>
            <li class="nav-item"><a class="nav-link" href="/patient/feedback"><i class="bi bi-star me-2"></i>Feedback</a></li>
        </ul>
        <hr class="border-secondary" />
        <div class="px-3 pb-3">
            <a href="/logout" class="btn btn-outline-light btn-sm w-100"><i class="bi bi-box-arrow-left me-1"></i>Logout</a>
        </div>
    </nav>
    <div class="main-content">
        <nav class="navbar navbar-light bg-white border-bottom px-4">
            <span class="navbar-brand fw-semibold text-success">My Health Portal</span>
            <small class="text-muted ms-auto" id="nav-date"></small>
        </nav>
        <div class="container-fluid p-4">@RenderBody()</div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const token = localStorage.getItem('maps_token');
    if (!token) window.location.href = '/login';
    document.getElementById('nav-date').textContent =
        new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
