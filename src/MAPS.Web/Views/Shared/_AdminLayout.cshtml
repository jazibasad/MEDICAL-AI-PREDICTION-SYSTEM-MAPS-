<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MAPS Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="maps-admin">

<div class="d-flex" id="wrapper">

    <!-- Sidebar -->
    <nav class="sidebar bg-dark" id="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">🏥</span>
            <span class="brand-text">MAPS Admin</span>
        </div>
        <hr class="border-secondary" />
        <ul class="nav flex-column px-2">
            <li class="nav-item">
                <a class="nav-link text-white @(ViewData["Title"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")"
                   href="/admin/dashboard">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @(ViewData["Title"]?.ToString()?.Contains("User") == true ? "active" : "")"
                   href="/admin/users">
                    <i class="bi bi-people me-2"></i> Users
                    <span id="sidebar-pending" class="badge bg-warning text-dark ms-auto d-none">0</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/admin/pending">
                    <i class="bi bi-clock-history me-2"></i> Pending Approvals
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @(ViewData["Title"]?.ToString()?.Contains("Assignment") == true ? "active" : "")"
                   href="/admin/assignments">
                    <i class="bi bi-diagram-3 me-2"></i> Assignments
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/admin/audit">
                    <i class="bi bi-journal-text me-2"></i> Audit Log
                </a>
            </li>
        </ul>
        <hr class="border-secondary" />
        <div class="px-3 pb-3">
            <a href="/logout" class="btn btn-outline-light btn-sm w-100">
                <i class="bi bi-box-arrow-left me-1"></i> Logout
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content flex-grow-1">
        <nav class="navbar navbar-light bg-white border-bottom px-4">
            <button class="btn btn-sm btn-outline-secondary" id="sidebar-toggle">
                <i class="bi bi-list"></i>
            </button>
            <span class="navbar-text ms-auto small text-muted" id="nav-user-info"></span>
        </nav>
        <div class="container-fluid p-4">
            @RenderBody()
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('sidebar-toggle').addEventListener('click', () => {
        document.getElementById('sidebar').classList.toggle('collapsed');
    });
    const token = localStorage.getItem('maps_token');
    if (!token) window.location.href = '/login';
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
