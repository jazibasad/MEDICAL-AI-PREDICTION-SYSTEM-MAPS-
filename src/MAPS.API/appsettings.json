{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=mapsdb;Username=maps_user;Password=${DB_PASSWORD}",
    "Redis": "redis:6379,abortConnect=false"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "MAPS.API",
    "Audience": "MAPS.Clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "MinIO": {
    "Endpoint": "minio:9000",
    "AccessKey": "${MINIO_ACCESS_KEY}",
    "SecretKey": "${MINIO_SECRET_KEY}",
    "BucketName": "maps-storage",
    "UseSSL": false
  },
  "Ollama": {
    "BaseUrl": "http://ollama:11434",
    "Model": "llama3",
    "Temperature": 0.3,
    "MaxTokens": 2048
  },
  "Whisper": {
    "BaseUrl": "http://maps-whisper:8090",
    "Language": "en"
  },
  "Hangfire": {
    "Dashboard": "/hangfire",
    "WorkerCount": 5
  },
  "RegistrationLock": {
    "IsLocked": true,
    "RequireAdminApproval": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "app", "value": "maps-api" },
            { "key": "env", "value": "development" }
          ]
        }
      }
    ]
  },
  "Swagger": {
    "Title": "MAPS API",
    "Version": "v1",
    "Description": "Medical AI Prediction System REST API"
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://localhost",
    "http://localhost:8080"
  ]
}
