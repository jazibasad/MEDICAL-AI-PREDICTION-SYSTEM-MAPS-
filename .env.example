# ============================================================
# MAPS — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to Git
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=ChangeThisStrongPassword123!

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET_KEY=ChangeThisToAVeryLongSecretKeyForJWTSigningMinimum32Chars!

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=ChangeThisRedisPassword!

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ACCESS_KEY=mapsadmin
MINIO_SECRET_KEY=ChangeThisMinioSecret123!

# ── Ollama LLM ────────────────────────────────────────────────────────────────
# Model to use — llama3 recommended (pull with: docker exec maps-ollama ollama pull llama3)
OLLAMA_MODEL=llama3

# ── Registration Lock ─────────────────────────────────────────────────────────
# Set to true in production — new accounts need admin approval
REGISTRATION_LOCKED=true
REQUIRE_ADMIN_APPROVAL=true

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=ChangeThisGrafanaPassword!

# ── Application ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
